# Copy to .env.local and fill in values from deploy.ps1 output
# VITE_ prefix makes these available at build time in the React app

# Base URL of the APIM gateway (set after infra is deployed)
VITE_API_BASE_URL=https://<apim-name>.azure-api.net

# If supervisor API is exposed separately (or through APIM)
VITE_SUPERVISOR_BASE_URL=https://<apim-name>.azure-api.net
